# At least one API source must be configured.

# Option 1: SerpApi (Google Flights) - recommended, 250 free calls/month
# Sign up at: https://serpapi.com
SERPAPI_KEY=your_serpapi_key_here

# Option 2: Duffel - search free, pay per booking ($3 + 1%)
# Sign up at: https://duffel.com
DUFFEL_API_TOKEN=your_duffel_token_here

# Cache TTL in minutes (default: 15)
CACHE_TTL_MINUTES=15

# SQLite database path (default: ./data/flightsearch.db)
DATABASE_PATH=./data/flightsearch.db
